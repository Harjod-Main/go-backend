# Server
ENV=LOCAL
HOSTNAME=localhost
PORT=8080

# Access Control
ACCESS_CONTROL_ALLOW_ORIGIN=*

# Header
REF_ID_HEADER_KEY=X-Ref-Id

# Supabase (required for Harjod foundation)
# Project URL example: https://xxxx.supabase.co
SUPABASE_PROJECT_URL=
# JWT secret from Supabase Dashboard → Project Settings → API → JWT Secret
SECRET_SUPABASE_JWT_SECRET=
# Audience for user access tokens
SUPABASE_JWT_AUDIENCE=authenticated

# Postgres / Supabase DB (required)
# Preferred: full connection string from Supabase (Session mode / direct)
# DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=
# Or discrete fields:
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_SSLMODE=require
SECRET_DB_USER=postgres
SECRET_DB_PASSWORD=

# --- Legacy custom Go auth (optional; not used by default routes) ---
JWT_ISSUER=
JWT_AUDIENCE=
JWT_EXP_DURATION=24h
SECRET_JWT_PRIVATE_KEY=
GOOGLE_OAUTH2_VERIFY_TOKEN=https://oauth2.googleapis.com/tokeninfo
GOOGLE_OAUTH2_GET_USER_PROFILE=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_OAUTH2_REVOKE_TOKEN=https://oauth2.googleapis.com/revoke
SECRET_AESGCM_KEY=
SECRET_HASH_PEPPER=
